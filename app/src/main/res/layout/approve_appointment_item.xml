<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:backgroundTint="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E5E7EB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- AVATAR -->
            <TextView
                android:id="@+id/text_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="JD"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_avatar_circle"/>

            <!-- NAME + INFO -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <!-- NAME + STATUS -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/text_view_item_approve_appointment_patient_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="John Doe"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/chip_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textColor="#92400E"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:background="@drawable/bg_status_pending"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <!-- CONTACT -->
                <TextView
                    android:id="@+id/text_view_item_approve_patient_contact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact · 1111111111"
                    android:textColor="#6B7280"
                    android:textSize="15sp"
                    android:layout_marginTop="6dp"/>

                <!-- DATE -->
                <TextView
                    android:id="@+id/text_view_item_approve_appointment_datetime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 Mar 2026 · 10:00 AM"
                    android:textColor="#374151"
                    android:textSize="15sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </LinearLayout>


        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E7EB"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>


        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- REJECT -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_item_reject_appointment"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Reject"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#B91C1C"
                android:backgroundTint="@android:color/white"
                app:strokeColor="#D1D5DB"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"/>

            <Space
                android:layout_width="16dp"
                android:layout_height="1dp"/>

            <!-- ACCEPT -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_item_accept_appointment"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Accept"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#16A34A"
                app:cornerRadius="16dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
