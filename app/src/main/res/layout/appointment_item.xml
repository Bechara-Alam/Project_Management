<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <!-- Doctor Image -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imageDoctor"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/doctor1"
            android:scaleType="centerCrop"
            app:civ_border_width="2dp"
            app:civ_border_color="#E2E8F0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Doctor Name -->
        <TextView
            android:id="@+id/textDoctorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Doctor Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/imageDoctor"
            app:layout_constraintTop_toTopOf="@id/imageDoctor"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Date Icon -->
        <ImageView
            android:id="@+id/iconDate"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_calendar"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="@id/textDoctorName"
            app:layout_constraintTop_toBottomOf="@id/textDoctorName"/>

        <!-- Date Text -->
        <TextView
            android:id="@+id/textDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textSize="15sp"
            android:textColor="#475569"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/iconDate"
            app:layout_constraintTop_toTopOf="@id/iconDate"/>

        <!-- Time Icon -->
        <ImageView
            android:id="@+id/iconTime"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_clock"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="@id/textDoctorName"
            app:layout_constraintTop_toBottomOf="@id/iconDate"/>

        <!-- Time Text -->
        <TextView
            android:id="@+id/textTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time"
            android:textSize="15sp"
            android:textColor="#475569"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/iconTime"
            app:layout_constraintTop_toTopOf="@id/iconTime"/>

        <!-- ✅ PAYMENT STATUS -->
        <TextView
            android:id="@+id/textPaymentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment: Pending"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/textTime"
            app:layout_constraintStart_toStartOf="@id/textDoctorName"/>

        <!-- ✅ PAY BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_pay_now"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Pay Now"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#2D6CDF"
            android:layout_marginTop="12dp"
            app:cornerRadius="20dp"
            app:layout_constraintTop_toBottomOf="@id/textPaymentStatus"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
