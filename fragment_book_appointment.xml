<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Doctor -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Doctor"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#333"/>

        <Spinner
            android:id="@+id/spinner_appointment_doctors"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_field_rounded"/>

        <!-- Select Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#333"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:id="@+id/layoutCalendarClick"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_field_rounded"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/textSelectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to choose date"
                android:textColor="#666"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Time Slots -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available Time"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#333"
            android:layout_marginTop="20dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSlots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:singleSelection="true"
            app:chipSpacing="8dp"/>

        <!-- ✅ UPDATED BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_proceed_payment"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Submit Appointment"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_marginTop="32dp"
            app:cornerRadius="28dp"
            android:backgroundTint="#2D6CDF"/>

    </LinearLayout>
</ScrollView>